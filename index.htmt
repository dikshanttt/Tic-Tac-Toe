<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Neon Tic Tac Toe</title>
  <style>
    * { box-sizing: border-box; }

    body {
      font-family: "Poppins", sans-serif;
      background: radial-gradient(circle at center, #2b1055, #000000);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      flex-direction: column;
      color: white;
    }

    h1 {
      color: #fff;
      margin-bottom: 15px;
      text-shadow: 0 0 20px #ff00ff;
    }

    .controls {
      margin-bottom: 15px;
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
      justify-content: center;
    }

    /* Neon Dropdown */
    .dropdown {
      position: relative;
      display: inline-block;
      width: 140px;
      color: #00ffff;
      font-size: 1rem;
      cursor: pointer;
      user-select: none;
    }

    .dropdown-selected {
      background: linear-gradient(145deg, rgba(25, 25, 40, 0.9), rgba(15, 10, 40, 0.8));
      border: 2px solid #00ffff;
      border-radius: 10px;
      padding: 10px 14px;
      box-shadow: 0 0 20px rgba(0, 255, 255, 0.4);
      text-shadow: 0 0 10px #00ffff;
      transition: all 0.3s ease;
    }

    .dropdown-selected::after {
      content: "▼";
      float: right;
      color: #00ffff;
      font-size: 0.8em;
      margin-top: 2px;
      transition: transform 0.3s;
    }

    .dropdown.active .dropdown-selected::after { transform: rotate(180deg); }

    .dropdown-options {
      display: none;
      position: absolute;
      width: 100%;
      background: rgba(20, 10, 40, 0.95);
      border: 1px solid #00ffff;
      border-radius: 10px;
      margin-top: 6px;
      box-shadow: 0 0 20px rgba(0, 255, 255, 0.4);
      overflow: hidden;
      z-index: 10;
    }

    .dropdown.active .dropdown-options { display: block; animation: fadeIn 0.2s ease; }

    .option {
      padding: 10px 14px;
      transition: all 0.25s ease;
      color: #fff;
    }

    .option:hover {
      background: #00ffff;
      color: #000;
      text-shadow: none;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    label {
      font-weight: 500;
      color: #ff00ff;
      text-shadow: 0 0 10px #ff00ff, 0 0 20px #ff00ff;
      margin-right: 8px;
    }

    .board {
      display: grid;
      grid-template-columns: repeat(3, 100px);
      grid-template-rows: repeat(3, 100px);
      gap: 10px;
      background: linear-gradient(145deg, #3a0ca3, #7209b7);
      padding: 15px;
      border-radius: 20px;
      box-shadow: 0 0 30px rgba(114, 9, 183, 0.5);
    }

    .cell {
      background: radial-gradient(circle at 30% 30%, #2b1055, #1a0535);
      border: 2px solid rgba(255, 255, 255, 0.15);
      border-radius: 15px;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 2.5em;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: inset 0 0 10px rgba(255, 255, 255, 0.1);
    }

    .cell:hover { transform: scale(1.05); box-shadow: 0 0 20px rgba(255, 255, 255, 0.2); }

    .cell.X { color: #00ffff; text-shadow: 0 0 15px #00ffff, 0 0 30px #00ffff; }
    .cell.O { color: #ff00ff; text-shadow: 0 0 15px #ff00ff, 0 0 30px #ff00ff; }

    #status {
      margin-top: 20px;
      font-size: 1.2rem;
      text-shadow: 0 0 10px #fff;
    }

    button {
      margin-top: 15px;
      padding: 10px 20px;
      font-size: 1rem;
      border: none;
      border-radius: 8px;
      background-color: #00bfff;
      color: white;
      cursor: pointer;
      transition: background 0.3s;
      box-shadow: 0 0 15px #00bfff;
    }

    button:hover { background-color: #0088cc; }
  </style>
</head>
<body>
  <h1>Neon Tic Tac Toe</h1>

  <div class="controls">
    <label>Mode:</label>
    <div class="dropdown" id="modeDropdown">
      <div class="dropdown-selected" id="modeSelected">Vs Bot</div>
      <div class="dropdown-options" id="modeOptions">
        <div class="option" data-value="bot">Vs Bot</div>
        <div class="option" data-value="2p">2 Players</div>
      </div>
    </div>
  </div>

  <div class="controls">
    <label>Difficulty:</label>
    <div class="dropdown" id="dropdown">
      <div class="dropdown-selected" id="dropdownSelected">Easy</div>
      <div class="dropdown-options" id="dropdownOptions">
        <div class="option" data-value="easy">Easy</div>
        <div class="option" data-value="medium">Medium</div>
        <div class="option" data-value="hard">Hard</div>
      </div>
    </div>
  </div>

  <div class="board" id="board">
    <div class="cell" data-index="0"></div>
    <div class="cell" data-index="1"></div>
    <div class="cell" data-index="2"></div>
    <div class="cell" data-index="3"></div>
    <div class="cell" data-index="4"></div>
    <div class="cell" data-index="5"></div>
    <div class="cell" data-index="6"></div>
    <div class="cell" data-index="7"></div>
    <div class="cell" data-index="8"></div>
  </div>

  <div id="status">Your turn (X)</div>
  <button id="reset">Restart Game</button>

  <script>
    const cells = document.querySelectorAll(".cell");
    const statusText = document.getElementById("status");
    const resetBtn = document.getElementById("reset");

    let board = ["", "", "", "", "", "", "", "", ""];
    let currentPlayer = "X";
    let running = true;
    let difficulty = "easy";
    let gameMode = "bot";

    const winPatterns = [
      [0,1,2],[3,4,5],[6,7,8],
      [0,3,6],[1,4,7],[2,5,8],
      [0,4,8],[2,4,6]
    ];

    // --- Event listeners ---
    cells.forEach(cell => cell.addEventListener("click", cellClicked));
    resetBtn.addEventListener("click", restartGame);

    // Difficulty dropdown
    const dropdown = document.getElementById("dropdown");
    const dropdownSelected = document.getElementById("dropdownSelected");
    const optionElems = document.querySelectorAll("#dropdownOptions .option");

    dropdownSelected.addEventListener("click", () => dropdown.classList.toggle("active"));
    optionElems.forEach(opt => {
      opt.addEventListener("click", () => {
        difficulty = opt.getAttribute("data-value");
        dropdownSelected.textContent = opt.textContent;
        dropdown.classList.remove("active");
        restartGame();
      });
    });

    // Mode dropdown
    const modeDropdown = document.getElementById("modeDropdown");
    const modeSelected = document.getElementById("modeSelected");
    const modeElems = document.querySelectorAll("#modeOptions .option");

    modeSelected.addEventListener("click", () => modeDropdown.classList.toggle("active"));
    modeElems.forEach(opt => {
      opt.addEventListener("click", () => {
        gameMode = opt.getAttribute("data-value");
        modeSelected.textContent = opt.textContent;
        modeDropdown.classList.remove("active");
        restartGame();
      });
    });

    window.addEventListener("click", (e) => {
      if (!dropdown.contains(e.target)) dropdown.classList.remove("active");
      if (!modeDropdown.contains(e.target)) modeDropdown.classList.remove("active");
    });

    // --- Game Logic ---
    function cellClicked() {
      const index = this.dataset.index;
      if (board[index] !== "" || !running) return;

      if (gameMode === "2p") {
        playMove(index, currentPlayer);
        currentPlayer = currentPlayer === "X" ? "O" : "X";
        statusText.textContent = `Player ${currentPlayer}'s turn`;
      } else {
        if (currentPlayer !== "X") return;
        playMove(index, "X");
        if (running) setTimeout(botMove, 500);
      }
    }

    function playMove(index, player) {
      board[index] = player;
      const cell = cells[index];
      cell.textContent = player;
      cell.classList.add(player);
      checkWinner();
    }

    function checkWinner() {
      let winner = null;
      for (let condition of winPatterns) {
        const [a,b,c] = condition;
        if (board[a] && board[a] === board[b] && board[a] === board[c]) {
          winner = board[a]; break;
        }
      }

      if (winner) {
        if(gameMode==="2p") statusText.textContent = `🎉 Player ${winner} Wins!`;
        else statusText.textContent = winner==="X" ? "🎉 You Win!" : "🤖 Bot Wins!";
        running=false;
      } else if (!board.includes("")) {
        statusText.textContent = "🤝 It's a Draw!"; running=false;
      } else {
        if(gameMode==="bot") {
          currentPlayer = currentPlayer==="X"?"O":"X";
          statusText.textContent = currentPlayer==="X"?"Your turn (X)":"Bot thinking...";
        }
      }
    }

    function botMove() {
      if (!running) return;
      let move;
      if(difficulty==="easy") move=randomMove();
      else if(difficulty==="medium") move=Math.random()<0.5?bestMove():randomMove();
      else move=bestMove();
      playMove(move,"O");
    }

    function randomMove() {
      const available = board.map((v,i)=>v===""?i:null).filter(v=>v!==null);
      return available[Math.floor(Math.random()*available.length)];
    }

    const scores = { O:1, X:-1, tie:0 };

    function bestMove() {
      let bestScore=-Infinity, move;
      for(let i=0;i<9;i++){
        if(board[i]===""){
          board[i]="O";
          let score=minimax(board,0,false);
          board[i]="";
          if(score>bestScore){bestScore=score;move=i;}
        }
      }
      return move;
    }

    function minimax(board,depth,isMaximizing){
      let result=evaluate(board);
      if(result!==null) return scores[result];
      if(isMaximizing){
        let bestScore=-Infinity;
        for(let i=0;i<9;i++){
          if(board[i]===""){
            board[i]="O";
            let score=minimax(board,depth+1,false);
            board[i]="";
            bestScore=Math.max(score,bestScore);
          }
        }
        return bestScore;
      }else{
        let bestScore=Infinity;
        for(let i=0;i<9;i++){
          if(board[i]===""){
            board[i]="X";
            let score=minimax(board,depth+1,true);
            board[i]="";
            bestScore=Math.min(score,bestScore);
          }
        }
        return bestScore;
      }
    }

    function evaluate(board){
      for(let pattern of winPatterns){
        const [a,b,c]=pattern;
        if(board[a] && board[a]===board[b] && board[a]===board[c]) return board[a];
      }
      if(!board.includes("")) return "tie";
      return null;
    }

    function restartGame() {
      board=["","","","","","","","",""];
      currentPlayer="X"; running=true;
      cells.forEach(cell=>{ cell.textContent=""; cell.classList.remove("X","O"); });
      statusText.textContent="Your turn (X)";

      // Disable difficulty selection for 2P
      if(gameMode==="2p"){ dropdownSelected.style.pointerEvents="none"; dropdownSelected.style.opacity=0.5; }
      else { dropdownSelected.style.pointerEvents="auto"; dropdownSelected.style.opacity=1; }
    }

    // initialize
    restartGame();
  </script>
</body>
</html>
